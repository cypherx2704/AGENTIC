# CypherX Tool Registry — example environment (placeholders only, NO real secrets).
# Copy to .env for local dev. All vars are read directly from the environment (no prefix).

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=tool-registry
SERVICE_VERSION=0.1.0
ENVIRONMENT=local

# ── PostgreSQL (runtime role tool_user, tools schema) ───────────────────────────
DATABASE_URL=postgresql://tool_user:localdev@localhost:5432/cypherx_platform

# ── Valkey (SOFT dependency — /readyz reports it but never gates readiness) ─────
VALKEY_URL=redis://localhost:6379/0
VALKEY_PING_TIMEOUT_SECONDS=2.0

# ── Auth / JWKS (Contract 1). Point at the running auth-service. ────────────────
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform

# ── Token revocation (WP03 — shared verifier-side kill-switch mirror). Fail-open. ─
REVOCATION_CHECK_ENABLED=true
REVOCATION_KEY_PREFIX=cypherx:rev:
REVOCATION_VALKEY_TIMEOUT_SECONDS=0.15

# ── Tool registration: max ACTIVE versions retained per tool (oldest retired). ──
MAX_ACTIVE_VERSIONS_PER_TOOL=3

# ── Manifest health poll. Background sweep + per-poll timeout + failure thresholds. ─
HEALTH_POLL_INTERVAL_SECONDS=30.0
HEALTH_POLL_TIMEOUT_SECONDS=5.0
HEALTH_DEGRADE_AFTER=1
HEALTH_OFFLINE_AFTER=3

# ── Discovery: hard cap on rows returned by GET /v1/tools. ──────────────────────
DISCOVERY_MAX_TOOLS=500
