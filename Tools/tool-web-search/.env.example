# CypherX tool-web-search MCP server — example environment (placeholders only, NO real keys).
# Copy to .env for local dev. All vars are read directly from the environment (no prefix).

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=tool-web-search
SERVICE_VERSION=0.1.0
ENVIRONMENT=local

# ── Search provider (pluggable). mock = deterministic, no network (default). ────
# mock | serpapi | brave
SEARCH_PROVIDER=mock
# Real-provider keys (leave blank in mock mode — NEVER commit a real value).
SERPAPI_API_KEY=
BRAVE_API_KEY=
PROVIDER_TIMEOUT_SECONDS=10.0
DEFAULT_MAX_RESULTS=5
MAX_MAX_RESULTS=20

# ── Valkey (SOFT dependency: rate limit + idempotency only; fail-open). ─────────
VALKEY_URL=redis://localhost:6379/0
VALKEY_PING_TIMEOUT_SECONDS=2.0

# ── Auth / JWKS (Contract 1). Point at the running auth-service. ────────────────
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform

# ── Token revocation (WP03 shared mirror). Fail-open. ───────────────────────────
REVOCATION_CHECK_ENABLED=true
REVOCATION_KEY_PREFIX=cypherx:rev:
REVOCATION_VALKEY_TIMEOUT_SECONDS=0.15

# ── MCP manifest (Contract 4). ──────────────────────────────────────────────────
MANIFEST_SCHEMA_VERSION=1.0.0
MANIFEST_PROTOCOL_VERSION=mcp/1.0
TOOL_TIMEOUT_SECONDS=30

# ── Output cap (Contract 4 invoke). Over -> 413 PAYLOAD_TOO_LARGE. 10 MiB. ──────
MAX_OUTPUT_BYTES=10485760

# ── Per-tenant rate limiting (fail-open Valkey fixed-window). ───────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MIN=60
RATE_LIMIT_KEY_PREFIX=cypherx:tws:rl:
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_VALKEY_TIMEOUT_SECONDS=0.15

# ── Idempotency (Contract-9 style; Valkey-backed, fail-open). ───────────────────
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_KEY_PREFIX=cypherx:tws:idem:
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_VALKEY_TIMEOUT_SECONDS=0.15

# ── Request body cap. Over -> 413 PAYLOAD_TOO_LARGE. 1 MiB. ─────────────────────
MAX_REQUEST_BODY_BYTES=1048576
