# tool-flow-bridge — example environment (no prefix; Doppler injects in cloud).

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=tool-flow-bridge
SERVICE_VERSION=0.1.0
ENVIRONMENT=local
HOST=0.0.0.0
PORT=8096

# ── Postgres (role flow_tools_user, schema flow_tools) ────────────────────────
DATABASE_URL=postgresql://flow_tools_user:localdev@localhost:5432/cypherx_platform

# ── Valkey (soft) ─────────────────────────────────────────────────────────────
VALKEY_URL=redis://localhost:6379/0

# ── Auth / JWKS (Contract 1) ──────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform

# ── Contract-12 service token (bridge -> Auth -> Tool Registry) ───────────────
AUTH_SERVICE_URL=http://localhost:8080
SERVICE_PRINCIPAL_NAME=tool-flow-bridge
SERVICE_BOOTSTRAP_SECRET=local-dev-flowbridge-secret

# ── Tool Registry ─────────────────────────────────────────────────────────────
TOOL_REGISTRY_URL=http://localhost:8089

# ── This bridge's reachable base URL (drives each tool's manifest base_url) ───
BRIDGE_BASE_URL=http://tool-flow-bridge:8080

# ── Node-RED (execution backend) ──────────────────────────────────────────────
NODERED_INVOKE_SECRET_HEADER=X-CypherX-Tool-Secret
# Must equal the Node-RED httpAdminRoot and the BFF proxy path so the iframed editor's
# asset URLs resolve behind the BFF.
NODERED_ADMIN_ROOT=/bff/nodered

# ── Provisioner: static (shared dev instance) | docker | kubernetes ───────────
PROVISIONER_MODE=static
STATIC_NODERED_INTERNAL_HOST=http://nodered:1880
STATIC_NODERED_HTTP_NODE_ROOT=/flow
STATIC_NODERED_ADMIN_TOKEN=local-dev-nodered-admin-token
STATIC_NODERED_INVOKE_SECRET=local-dev-nodered-invoke-secret
STATIC_NODERED_CREDENTIAL_SECRET=local-dev-nodered-credential-secret

# ── Kubernetes provisioner (production; ignored in static mode) ───────────────
NODERED_IMAGE=cypherx/nodered-tenant:local
NODERED_NAMESPACE=cypherx-tools
NODERED_RUNTIME_CLASS=
NODERED_EGRESS_ALLOW_CIDRS=
# Shared per-Node-RED secrets injected as env in k8s/docker modes:
# NODERED_ADMIN_TOKEN=...
# NODERED_INVOKE_SECRET=...
# NODERED_CREDENTIAL_SECRET=...

# ── Publishing default (publisher can override per tool) ──────────────────────
DEFAULT_ACCESS_MODE=ask
