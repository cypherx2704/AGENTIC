# CypherX Memory Service — example environment (copy to .env for local dev).
# All keys are read from the process env with NO prefix (Doppler convention).

# ── Service identity ────────────────────────────────────────────────────────────
ENVIRONMENT=local

# ── PostgreSQL (PgBouncer -> memory schema, runtime user mem_user) ──────────────
DATABASE_URL=postgresql://mem_user:localdev@localhost:5432/cypherx_platform

# ── Kafka / Valkey ──────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
VALKEY_URL=redis://localhost:6379/0

# ── Auth / JWKS (Contract 1) ─────────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform

# ── Embeddings (llms-gateway POST /v1/embeddings) ────────────────────────────────
EMBEDDINGS_BASE_URL=http://localhost:8081
EMBEDDINGS_MODEL=embed
# EMBEDDINGS_SERVICE_TOKEN=<service JWT for the outbound embeddings call>
# Force the deterministic offline embedder (no network) — handy for local/offline dev:
EMBEDDINGS_MOCK_FALLBACK=false

# ── Store / retrieve bounds ──────────────────────────────────────────────────────
CONTENT_MAX_BYTES=16384
DEDUP_THRESHOLD=0.95
SEARCH_TOP_K_MAX=50

# ── TTL sweep + quota ────────────────────────────────────────────────────────────
TTL_SWEEP_ENABLED=true
TTL_SWEEP_INTERVAL_SECONDS=300
QUOTA_ENABLED=true
DEFAULT_PLAN=free

# ── Retrieval scoring (Generative Agents composite). OFF -> pure-cosine, unchanged. ─
MEMORY_SCORING_ENABLED=false
MEMORY_SCORING_WEIGHT_RECENCY=1.0
MEMORY_SCORING_WEIGHT_IMPORTANCE=1.0
MEMORY_SCORING_WEIGHT_RELEVANCE=1.0
MEMORY_SCORING_RECENCY_HALF_LIFE_SECONDS=604800
# Optional LLM-graded importance on write (OFF -> deterministic heuristic only):
MEMORY_IMPORTANCE_LLM_ENABLED=false

# ── Contradiction / temporal validity (supersession). OFF -> unchanged. ─────────────
MEMORY_CONTRADICTION_ENABLED=false
MEMORY_CONTRADICTION_SIM_MIN=0.80
# Hide superseded memories from search by default (independent reader toggle):
MEMORY_SEARCH_CURRENT_ONLY=true

# ── Consolidation / forgetting (opt-in background routine). OFF -> never runs. ──────
MEMORY_CONSOLIDATION_ENABLED=false
MEMORY_CONSOLIDATION_INTERVAL_SECONDS=86400
MEMORY_CONSOLIDATION_MIN_AGE_SECONDS=2592000
MEMORY_CONSOLIDATION_MAX_IMPORTANCE=0.30
MEMORY_CONSOLIDATION_BATCH_SIZE=200

# ── Usage metering (Contract-19.1 cypherx.memory.usage.recorded via the outbox) ────
MEMORY_USAGE_EVENTS_ENABLED=true

# ── B1: halfvec / binary vector quantization for the ANN scan. off -> unchanged. ────
MEMORY_VECTOR_QUANTIZATION=off             # off | halfvec | binary_rerank

# ── B2: content-hash embedding cache (Valkey). OFF -> every store/search re-embeds. ─
MEMORY_EMBEDDING_CACHE_ENABLED=false
MEMORY_EMBEDDING_CACHE_TTL_SECONDS=604800
MEMORY_EMBEDDING_CACHE_KEY_PREFIX=cypherx:mem:emb:

# ── B3: explicit HNSW build params + query-time ef_search. 0 -> GUC not emitted. ────
MEMORY_HNSW_M=16
MEMORY_HNSW_EF_CONSTRUCTION=64
MEMORY_HNSW_EF_SEARCH=0

# ── B4: ACT-R recency x frequency decay. exponential + weight 0 -> unchanged. ───────
MEMORY_SCORING_DECAY=exponential           # exponential | power_actr
MEMORY_SCORING_FREQUENCY_WEIGHT=0.0
MEMORY_ACTR_DECAY_D=0.5

# ── B5: salient-fact extraction at ingest. OFF -> single-row store, unchanged. ──────
MEMORY_EXTRACTION_ENABLED=false
MEMORY_EXTRACTION_LLM_ENABLED=false
MEMORY_EXTRACTION_MAX_FACTS=16

# ── B6: MMR diversity re-rank. OFF -> pure-cosine order, unchanged. ─────────────────
MEMORY_MMR_ENABLED=false
MEMORY_MMR_LAMBDA=0.5

# ── B7: associative linking + 1-hop graph expansion. OFF -> vector-only, unchanged. ─
MEMORY_LINKING_ENABLED=false
MEMORY_LINKING_MAX_NEIGHBORS=3
MEMORY_LINKING_SIM_MIN=0.50
MEMORY_LINKING_EXPANSION_LIMIT=10
