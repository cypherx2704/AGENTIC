# CypherX LLMs Gateway — example environment (placeholders only, NO real keys).
# Copy to .env for local dev. All vars are read directly from the environment (no prefix).

# ── Service identity ──────────────────────────────────────────────────────────
SERVICE_NAME=llms-gateway
SERVICE_VERSION=0.1.0
ENVIRONMENT=local

# ── Behaviour ──────────────────────────────────────────────────────────────────
# true => use the deterministic mock provider (no keys / no network).
MOCK_PROVIDERS=true

# ── Rerank (POST /v1/rerank). Pluggable provider; DEFAULT is the keyless MOCK. ──
# mock  => deterministic lexical-overlap scorer (no keys / no network / stable offline).
# local => cross-encoder (bge-reranker class) — NOT in the default image (heavy deps);
#          the seam returns 503 until a model runtime is provisioned.
RERANK_PROVIDER=mock
RERANK_DEFAULT_MODEL=rerank-default
RERANK_LOCAL_MODEL=BAAI/bge-reranker-base
RERANK_MAX_DOCUMENTS=256
RERANK_MAX_PAYLOAD_BYTES=26214400

# ── Safety classify (POST /v1/classify). DEFAULT is the deterministic STUB. ─────
# stub  => keyword/permissive classifier (verdict=allow + empty scores for clean text).
# local => small safety model (Llama Guard / ShieldGemma / Prompt Guard class) — NOT
#          in the default image; the seam returns 503 until provisioned.
CLASSIFIER_MODE=stub
CLASSIFIER_DEFAULT_MODEL=safety-default
CLASSIFIER_LOCAL_MODEL=meta-llama/Llama-Guard-3-1B
CLASSIFY_MAX_INPUT_BYTES=1048576

# ── PostgreSQL (runtime role llms_user, llms schema) ────────────────────────────
DATABASE_URL=postgresql://llms_user:localdev@localhost:5432/cypherx_platform

# ── Kafka ────────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Auth / JWKS (Contract 1). Point at the running auth-service. ────────────────
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform

# ── Plan / limits resolution (WP05). Auth HTTP fallback is a stub for now. ──────
AUTH_BASE_URL=http://localhost:8080
DEFAULT_PLAN=free
PLAN_CACHE_TTL_SECONDS=60

# ── Rate limiting (WP05). Fail-open: a Valkey outage never blocks requests. ─────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_KEY_PREFIX=cypherx:llms:rl:
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_VALKEY_TIMEOUT_SECONDS=0.15

# ── Idempotency (WP05, Contract-9). Fail-open. Streams are replay-exempt. ───────
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_KEY_PREFIX=cypherx:llms:idem:
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_IN_FLIGHT_TTL_SECONDS=300
IDEMPOTENCY_VALKEY_TIMEOUT_SECONDS=0.15

# ── Provider keys (platform-managed). Leave blank in mock mode. ────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── BYOK (bring-your-own-key, WP06). Master key-encryption-key (KEK). ──────────
# Wraps each per-secret AES-256-GCM DEK in a sealed:v1 envelope. LEAVE BLANK to
# DISABLE BYOK (registration is refused, the resolver returns None, every provider
# call uses the platform key above). Any passphrase >= 1 char works (HKDF-derived to
# 32 bytes); use a strong, random 32+ byte secret in prod. NEVER commit a real value.
LLMS_BYOK_KEK=
# Grace window (days) after a key rotation during which BOTH the old + new key serve.
BYOK_GRACE_DAYS=7

# ── Per-key ACLs (WP06, Contract-18). Opt-in; a key with no rows is unrestricted. ─
# Master switch. When a key HAS llms.api_key_acls rows the resolved model/provider/
# operation must be permitted by >=1 row else 403 ACL_DENIED. Fails OPEN (allow) with
# no DB pool / no rows for the key.
ACL_ENABLED=true

# ── Request body + multimodal image caps (WP06). Over -> 413 PAYLOAD_TOO_LARGE. ──
# Hard ceiling on the inbound request body (Content-Length + streamed). 25 MiB default.
MAX_REQUEST_BODY_BYTES=26214400
# Per chat request: max image_url parts and max TOTAL decoded inline-image bytes.
MAX_IMAGES_PER_REQUEST=4
MAX_IMAGE_BYTES=20971520

# ── Image URL handling (WP06). Default = URL pass-through (fetcher NEVER invoked). ─
# true => download each image_url to inline base64 via the SSRF-hardened fetcher
# (scheme/IP allow-list, size cap, timeout, image/* content-type).
IMAGE_INLINE_REQUIRED=false
IMAGE_FETCH_MAX_BYTES=20971520
IMAGE_FETCH_TIMEOUT_SECONDS=5.0

# ── Pricing-staleness watchdog (WP06). WARN + optional webhook when pricing is old. ─
# Max age (seconds) of the newest provider_pricing.updated_at before STALE. 7d default.
PRICING_STALENESS_MAX_AGE_SECONDS=604800
# Alert sink. EMPTY = log-only (no webhook). Production also runs this from a scheduler.
PRICING_STALENESS_WEBHOOK_URL=
PRICING_STALENESS_WEBHOOK_TIMEOUT_SECONDS=3.0
