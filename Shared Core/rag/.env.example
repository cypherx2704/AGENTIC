# CypherX RAG service — example environment (copy to .env; never commit real secrets).
# Every value is env-overridable (pydantic-settings); nothing is hardcoded in code.

# ── Service identity ────────────────────────────────────────────────────────────
SERVICE_NAME=rag-service
ENVIRONMENT=local
PORT=8000

# ── PostgreSQL (PgBouncer -> rag schema, pgvector, runtime user rag_user) ────────
DATABASE_URL=postgresql://rag_user:localdev@localhost:5432/cypherx_platform

# ── Kafka / Valkey ───────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
VALKEY_URL=redis://localhost:6379/0

# ── Auth / JWKS (Contract 1) + service tokens (Contract 12) ──────────────────────
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform
AUTH_SERVICE_URL=http://localhost:8080
SERVICE_BOOTSTRAP_SECRET=local-dev-rag-secret

# ── LLMs gateway (embeddings) ────────────────────────────────────────────────────
LLMS_GATEWAY_URL=http://localhost:8085
# Flip true to use the deterministic in-process mock embedder (no network/service token).
MOCK_EMBEDDINGS=false
# When the real llms call fails, fall back to the deterministic mock vector (resilient local).
EMBEDDINGS_FALLBACK_TO_MOCK=true
# Env-pinned model/dim fallback when GET /v1/models is unreachable (bootstrap cold-start guard).
EMBEDDING_MODEL_RESOLVED=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Retrieval upgrades (ALL additive; defaults reproduce today's behaviour) ──────
# Hybrid (dense + lexical + RRF). search_mode is per-query and defaults to 'dense' (the
# two-pass HNSW path is untouched). These knobs only affect search_mode=hybrid|sparse.
HYBRID_RRF_K=60
HYBRID_CANDIDATE_MULTIPLIER=10
HYBRID_CANDIDATE_CAP=200
# Optional cross-encoder rerank via llms-gateway /v1/rerank. OFF by default — when on, a query
# with rerank=true pulls RERANK_CANDIDATE_N candidates then re-orders to top_k. Mock-tolerant.
RAG_RERANK_ENABLED=false
RERANK_CANDIDATE_N=150
RERANK_MODEL=rerank
RERANK_FALLBACK_TO_BASE=true
# MOCK_RERANK=false           # force the deterministic in-process reranker (inherits MOCK_EMBEDDINGS)
# Contextual ingest: generate a 1-2 sentence chunk context (llms-gateway /v1/chat/completions),
# prepend before embedding + fold into the lexical tsvector. OFF by default (ingest unchanged).
RAG_CONTEXTUAL_INGEST=false
CONTEXTUAL_MODEL=chat
CONTEXTUAL_MAX_DOC_CHARS=4000
CONTEXTUAL_MAX_CONTEXT_CHARS=320

# ── Object storage (MinIO/S3 — bucket names are env, never schema literals) ──────
S3_BUCKET=cypherx-rag-local
S3_ENDPOINT=http://localhost:9000
S3_SSE_MODE=none            # none | kms ('none' against MinIO; 'kms' is the cloud form)
# RAG_S3_KMS_KEY_ID=alias/cypherx-rag-<env>   # only used when S3_SSE_MODE=kms

# ── Ingestion worker (Kafka consumer; the dedicated worker process flips this on) ─
WORKER_ENABLED=false
INGESTION_TOPIC=cypherx.rag.ingestion.requested
INGESTION_CONSUMER_GROUP=cypherx-rag-ingestion-workers

# ── Quotas (Contract-19; resolved from the JWT plan/limits; fail-open) ───────────
QUOTA_ENABLED=true
DEFAULT_PLAN=free
