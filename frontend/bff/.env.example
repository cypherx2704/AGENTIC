# ─────────────────────────────────────────────────────────────────────────────
# CypherX BFF (WP13) — environment configuration. NEVER hardcode; 100% env-driven.
# Copy to .env and fill in. All secrets must be supplied by the deployment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# Host/port the BFF listens on.
BFF_HOST=0.0.0.0
BFF_PORT=8088
# Comma-separated allowed Origins for the SPA (CORS + CSRF origin checks). Empty = same-origin only.
BFF_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# ── Session store (Valkey / Redis) ───────────────────────────────────────────
# redis:// or rediss:// URL of the Valkey instance holding server-side sessions.
VALKEY_URL=redis://localhost:6379
# Key prefix for session entries in Valkey.
SESSION_KEY_PREFIX=cypherx:bff:sess:
# Session idle TTL in seconds (sliding; refreshed on each authenticated request).
SESSION_TTL_SECONDS=3600

# ── Session encryption-at-rest ───────────────────────────────────────────────
# 32-byte Key-Encryption-Key for AES-256-GCM, base64-encoded (44 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_KEK_BASE64=

# ── Cookies ──────────────────────────────────────────────────────────────────
# Name of the opaque session-id cookie (httpOnly, Secure, SameSite).
SESSION_COOKIE_NAME=cypherx_sid
# Name of the CSRF cookie (non-httpOnly so the SPA can read + echo it).
CSRF_COOKIE_NAME=cypherx_csrf
# SameSite policy for the session cookie: strict | lax | none.
COOKIE_SAMESITE=lax
# Set Secure attribute on cookies (true in prod/HTTPS; false only for local http dev).
COOKIE_SECURE=false
# Cookie path + optional domain.
COOKIE_PATH=/
COOKIE_DOMAIN=

# ── CSRF ─────────────────────────────────────────────────────────────────────
# Header the SPA echoes the CSRF token in.
CSRF_HEADER_NAME=x-csrf-token

# ── Security headers ─────────────────────────────────────────────────────────
# Content-Security-Policy (env-tunable). Keep this tight for a SPA.
CSP_POLICY=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data:; style-src 'self'; script-src 'self'; connect-src 'self'
# HSTS max-age in seconds (only emitted when COOKIE_SECURE/HTTPS).
HSTS_MAX_AGE=31536000
REFERRER_POLICY=no-referrer

# ── Upstream platform services (downstream proxy targets) ────────────────────
# Each maps to a `/bff/api/<name>/*` proxy prefix. Only AUTH_URL is mandatory; the
# rest are optional so the BFF can front a partial platform. Ports below are the
# infra/compose HOST mappings (for a BFF run on the host); in compose the BFF uses
# internal DNS + :8080 instead (see docker-compose.yml frontend-bff env).
AUTH_URL=http://localhost:8080
LLMS_URL=http://localhost:8085
GUARDRAILS_URL=http://localhost:8086
XAGENT_URL=http://localhost:8083
RAG_URL=http://localhost:8087
MEMORY_URL=http://localhost:8088
TOOL_REGISTRY_URL=http://localhost:8089
SKILL_REGISTRY_URL=http://localhost:8095
# Flow-Tool-Bridge (Tool Builder): publish API (/bff/api/toolbuilder/*) + editor proxy target.
TOOL_BUILDER_URL=http://localhost:8096
# Per-request timeout (ms) for non-streaming upstream calls.
UPSTREAM_TIMEOUT_MS=30000

# ── Dashboard cache ──────────────────────────────────────────────────────────
# TTL (seconds) for the per-tenant cache of expensive dashboard GETs (usage/cost/health).
DASHBOARD_CACHE_TTL_SECONDS=30
