# ── CypherX SPA environment (100% env-driven; nothing hardcoded) ──────────────────
#
# The SPA talks ONLY to the BFF. NEXT_PUBLIC_* values are inlined into the browser
# bundle at build time, so they must contain NO secrets (the BFF holds all secrets and
# the httpOnly session cookie). Copy this file to `.env.local` for local dev.

# Base URL of the BFF. The SPA prefixes every API call with this.
#   - Same-origin deploy (SPA + BFF behind one gateway): leave empty -> calls go to /bff/*
#   - Split origin (local dev, BFF on another port): set the full origin, e.g. http://localhost:8090
NEXT_PUBLIC_BFF_URL=

# The path prefix the BFF mounts its routes under. Almost always "/bff".
NEXT_PUBLIC_BFF_PREFIX=/bff

# Long-poll / refresh intervals (ms). Env-driven so ops can tune without a rebuild
# of the contract (these are NEXT_PUBLIC so they reach the browser).
NEXT_PUBLIC_TASK_FEED_POLL_MS=5000
NEXT_PUBLIC_HEALTH_POLL_MS=10000

# Display name shown in the shell header (purely cosmetic).
NEXT_PUBLIC_APP_NAME=CypherX
