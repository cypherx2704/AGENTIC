# mcp-eng-memory — example env (LOCAL-ONLY). Stateless: no DB, no Kafka.
SERVICE_NAME=mcp-eng-memory
ENVIRONMENT=local
PORT=8080

# Auth (Contract 1) — verifies inbound JWTs against the CypherX Auth JWKS.
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform

# Live revocation mirror (shared kill-switch; fail-open).
REVOCATION_CHECK_ENABLED=true
REVOCATION_KEY_PREFIX=cypherx:rev:
VALKEY_URL=redis://localhost:6379/0

# Backing product service (the cypherx-a1 internal API this facade proxies to).
CYPHERXA1_BASE_URL=http://localhost:8093
BACKEND_TIMEOUT_SECONDS=60

# MCP manifest source-of-truth (committed file).
MANIFEST_PATH=./manifest.json
MANIFEST_SCHEMA_VERSION=1.0.0
MANIFEST_PROTOCOL_VERSION=mcp/1.0

# Caps (Contract-4 platform standard).
MAX_REQUEST_BODY_BYTES=1048576
MAX_OUTPUT_BYTES=10485760
