# ─────────────────────────────────────────────────────────────────────────────
# cypherx-a1 — example environment (LOCAL-ONLY throwaways). Never commit a real .env.
# Real secrets come from Doppler; only this template is committed.
# All values here boot a keyless local dev machine; flip the mock toggles + supply
# keys to go live. Mirrors the platform .env.example conventions.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service identity ─────────────────────────────────────────────────────────
SERVICE_NAME=cypherx-a1
ENVIRONMENT=local

# ── PostgreSQL (Neon POOLED endpoint, runtime role cxa1_user, schema cypherx_a1) ──
# Compose sources this from CYPHERXA1_DATABASE_URL (Neon POOLED, sslmode=require).
DATABASE_URL=postgresql://cxa1_user:localdev@localhost:5432/cypherx_platform

# ── Auth / JWKS (Contract 1) ─────────────────────────────────────────────────
AUTH_JWKS_URL=http://localhost:8080/.well-known/jwks.json
AUTH_ISSUER_URL=http://localhost:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform
AUTH_SERVICE_URL=http://localhost:8080

# ── Service-to-service auth (Contract 12) ────────────────────────────────────
# REQUIRED, no default — boot fails fast if unset. Must equal Auth's configured value.
# Compose source: SERVICE_BOOTSTRAP_SECRET_CYPHERXA1.
SERVICE_BOOTSTRAP_SECRET=local-dev-cypherxa1-secret
SERVICE_PRINCIPAL_NAME=cypherx-a1

# ── Downstream SharedCore services (in-cluster DNS on :8080) ──────────────────
LLMS_GATEWAY_URL=http://localhost:8085
GUARDRAILS_SERVICE_URL=http://localhost:8086
RAG_SERVICE_URL=http://localhost:8087
MEMORY_SERVICE_URL=http://localhost:8088
TOOL_REGISTRY_URL=http://localhost:8089

# ── Kafka (Redpanda) + Valkey (soft) ─────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
VALKEY_URL=redis://localhost:6379/0

# ── RAG knowledge-base + embedding pin ───────────────────────────────────────
# Embedding model pinned EXPLICITLY (never the repointable 'embed' alias) so every KB
# shares one stable vector space. dim 1536 is the only platform-supported dimension.
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_DIM=1536

# ── Models ───────────────────────────────────────────────────────────────────
EXTRACTION_MODEL=smart
COPILOT_MODEL=smart

# ── Phase KG: knowledge-graph ACCURACY (ALL default to today's behavior — leave unset) ──
# Schema/ontology-guided extraction: constrain the LLM to the allowed relation/entity-type
# set; off-schema (hallucinated) relations are rejected ('reject') or flagged ('flag').
EXTRACTION_SCHEMA_ENABLED=false
EXTRACTION_SCHEMA_MODE=reject
# Extraction QA: record source span + the extractor's own confidence per edge (audit).
EXTRACTION_SPAN_CAPTURE_ENABLED=false
# Entity resolution / canonicalization: type-aware coreference ('J. Smith' = 'John Smith').
# Off by default (today only exact handle/email cross-tool identity resolution runs).
ENTITY_RESOLUTION_ENABLED=false
ENTITY_RESOLUTION_MIN_CONFIDENCE=0.85

# ── Connector: GitHub (MVP) ──────────────────────────────────────────────────
# Keyless local default: CONNECTOR_MODE=mock replays bundled fixtures (no GitHub token).
# Flip to CONNECTOR_MODE=live + set GITHUB_TOKEN + GITHUB_WEBHOOK_SECRET to go live.
CONNECTOR_MODE=mock
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=local-dev-webhook-secret
GITHUB_API_URL=https://api.github.com

# ── Worker selector ──────────────────────────────────────────────────────────
# CYPHERXA1_RUN_WORKER=1 starts the ingestion/extraction Kafka worker process instead
# of the API. Unset (default) runs the API.
CYPHERXA1_RUN_WORKER=
