# =====================================================================================================================
# infra/compose/.env.example — copy to .env and fill the values marked  <<< SET REAL NEON VALUE >>>.
#
#   cp .env.example .env   &&   edit .env
#
# POSTGRES IS EXTERNAL (Neon serverless). There is NO postgres container. Every service reads its DB DSN from the
# variables below. Two kinds of Neon endpoint:
#   * POOLED  (…-pooler.<region>.aws.neon.tech) — transaction mode — used by the APP services (compatible with the
#     Contract-13 SET LOCAL RLS pattern). sslmode=require MANDATORY.
#   * DIRECT  (no "-pooler" in the host)         — session mode      — used by the one-shot 'migrate' job ONLY
#     (migrations need session-level advisory locks). sslmode=require MANDATORY.
#
# Values shown are NEON-SHAPED PLACEHOLDERS. Replace USER / PW / EP-POOLER-HOST / EP-DIRECT-HOST with your project's
# real role, password, and endpoint hostnames. Everything NOT marked  <<< SET REAL NEON VALUE >>>  has a safe local
# default and can be left as-is for a local-dev run.
# =====================================================================================================================

# ---------------------------------------------------------------------------------------------------------------------
# 1. NEON POSTGRES DSNs — MUST be set to real Neon values.  (Database name assumed: cypherx_platform.)
#    Each Python service connects with libpq/psycopg using options=-c search_path=<schema>.
#    Auth connects with JDBC using currentSchema=auth; its username/password are SEPARATE env vars (NOT in the URL).
# ---------------------------------------------------------------------------------------------------------------------

# --- auth-service (JDBC; schema = auth). Username/password are SEPARATE (Hikari reads them; they are NOT in the URL).
# <<< SET REAL NEON VALUE >>>  (use the POOLED host; transaction mode is fine for the runtime app)
AUTH_DATABASE_URL=jdbc:postgresql://EP-POOLER-HOST/cypherx_platform?sslmode=require&currentSchema=auth
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR auth_user >>>

# --- llms-gateway (libpq/psycopg; schema = llms; runtime role llms_user)
# <<< SET REAL NEON VALUE >>>
LLMS_DATABASE_URL=postgresql://llms_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dllms

# --- guardrails-service (libpq/psycopg; schema = guardrails; runtime role grd_user)
# <<< SET REAL NEON VALUE >>>
GUARDRAILS_DATABASE_URL=postgresql://grd_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dguardrails

# --- xagent (libpq/psycopg; schema = xagent; runtime role xagent_user)
# <<< SET REAL NEON VALUE >>>
XAGENT_DATABASE_URL=postgresql://xagent_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dxagent

# --- rag-service (libpq/psycopg; schema = rag; runtime role rag_user; needs pgvector)
# <<< SET REAL NEON VALUE >>>
RAG_DATABASE_URL=postgresql://rag_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Drag

# --- memory-service (libpq/psycopg; schema = memory; runtime role mem_user; needs pgvector)
# <<< SET REAL NEON VALUE >>>
MEMORY_DATABASE_URL=postgresql://mem_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dmemory

# --- tool-registry (libpq/psycopg; schema = tools; runtime role tool_user)
# <<< SET REAL NEON VALUE >>>
TOOL_REGISTRY_DATABASE_URL=postgresql://tool_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dtools

# --- skill-registry (libpq/psycopg; schema = skills; runtime role skill_user) — Phase 8 mirror of tool-registry
# <<< SET REAL NEON VALUE >>>
SKILL_REGISTRY_DATABASE_URL=postgresql://skill_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dskills

# --- cypherx-a1 (CoreProjects; libpq/psycopg; schema = cypherx_a1; runtime role cxa1_user)
# <<< SET REAL NEON VALUE >>>
CYPHERXA1_DATABASE_URL=postgresql://cxa1_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dcypherx_a1

# --- tool-flow-bridge (Tool Builder; libpq/psycopg; schema = flow_tools; runtime role flow_tools_user)
# <<< SET REAL NEON VALUE >>>
FLOW_TOOLS_DATABASE_URL=postgresql://flow_tools_user:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require&options=-c%20search_path%3Dflow_tools

# --- migrate job (libpq; OWNER/admin role; DIRECT endpoint — session mode, advisory locks). Used by --profile migrate.
# <<< SET REAL NEON VALUE >>>  (note: DIRECT host, no "-pooler")
MIGRATE_DATABASE_URL=postgresql://OWNER:PW@EP-DIRECT-HOST/cypherx_platform?sslmode=require

# --- Runtime-role PASSWORDS for the migrate job's role-provisioning step (--profile migrate). These must MATCH the
#     PW embedded in each *_DATABASE_URL above. The migrate job runs ALTER ROLE ... WITH LOGIN PASSWORD for each.
#     Leave a var EMPTY to skip setting that role's password (e.g. if you set it manually in the Neon console).
# <<< SET REAL NEON PASSWORDS >>>
AUTH_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR auth_user >>>
LLMS_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR llms_user >>>
GUARDRAILS_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR grd_user >>>
XAGENT_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR xagent_user >>>
RAG_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR rag_user >>>
MEM_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR mem_user >>>
TOOL_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR tool_user >>>
SKILL_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR skill_user >>>
CYPHERXA1_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR cxa1_user >>>
FLOW_TOOLS_DB_PASSWORD=<<< SET REAL NEON PASSWORD FOR flow_tools_user >>>

# --- demo BFF (libpq; OWNER/admin DSN; used ONLY for the best-effort bootstrap-sentinel reset via psql). --profile demo
# <<< SET REAL NEON VALUE >>>  (can reuse MIGRATE_DATABASE_URL's owner DSN; pooled or direct both work)
DEMO_DB_URL=postgresql://OWNER:PW@EP-POOLER-HOST/cypherx_platform?sslmode=require

# ---------------------------------------------------------------------------------------------------------------------
# 2. IN-NETWORK SERVICE URLs (compose DNS on the 'cypherx' network). Defaults are correct for compose — leave as-is.
# ---------------------------------------------------------------------------------------------------------------------
AUTH_ISSUER_URL=http://auth-service:8080
AUTH_SERVICE_URL=http://auth-service:8080
AUTH_JWKS_URL=http://auth-service:8080/.well-known/jwks.json
AUTH_PLATFORM_AUDIENCE=cypherx-platform
LLMS_GATEWAY_URL=http://llms-gateway:8080
GUARDRAILS_SERVICE_URL=http://guardrails-service:8080
XAGENT_URL=http://xagent:8080
# WP09-11 data/tool services (xagent's WP12 stages + the BFF address these by internal DNS, port 8080).
RAG_SERVICE_URL=http://rag:8080
MEMORY_SERVICE_URL=http://memory:8080
TOOL_REGISTRY_URL=http://tool-registry:8080
TOOL_WEB_SEARCH_BASE_URL=http://tool-web-search:8080
SKILL_REGISTRY_URL=http://skill-registry:8080
# memory-service embeddings upstream (override its :8081 default — that collides with redpanda's schema registry).
MEMORY_EMBEDDINGS_BASE_URL=http://llms-gateway:8080

# ---------------------------------------------------------------------------------------------------------------------
# 3. BACKING DEP ENDPOINTS (containers on the 'cypherx' network). Defaults are correct — leave as-is.
# ---------------------------------------------------------------------------------------------------------------------
KAFKA_BROKERS=redpanda:29092
VALKEY_URL=redis://valkey:6379

# MinIO (S3 substitute) — LOCAL-ONLY throwaway creds (matches infra/dev/local defaults).
S3_ACCESS_KEY=cypherxlocal
S3_SECRET_KEY=cypherxlocal

# ---------------------------------------------------------------------------------------------------------------------
# 4. AUTH SECRETS — copied from Shared Core/auth/src/main/resources/application-local.yaml (LOCAL-ONLY, NOT real keys).
#    Needed because we run auth WITHOUT the 'local' Spring profile (so the Neon DSN takes effect), and the default
#    profile does NOT bake these in.
# ---------------------------------------------------------------------------------------------------------------------
AUTH_KEY_ENCRYPTOR=local
# Dev-only AES-256 master key (base64 of EXACTLY 32 bytes). LOCAL ONLY — cloud uses KMS.
AUTH_LOCAL_MASTER_KEY_B64=dOTCWIvKNfbl3uEaPSKz9gLHU83+q1gePY/AMZJOqVE=
# One-time super-admin bootstrap token (also used by the demo BFF as BOOTSTRAP_TOKEN). Change for anything non-local.
AUTH_BOOTSTRAP_TOKEN=local-bootstrap-token-change-me

# ---------------------------------------------------------------------------------------------------------------------
# 4b. SELF-SERVE ONBOARDING (Contract-20) — the public /register -> verify -> auto-login flow.
#   Local default: email goes to the 'mailpit' container (SMTP :1025); read the verification link at
#   http://localhost:8025. The link host is the edge (:8000), which redirects /v1/onboarding/verify ->
#   the SPA /register/verify page. Captcha is mock (the SPA sends captcha_token="mock").
#   PROD: set EMAIL_PROVIDER=smtp with SES/Resend SMTP host/port/username/password (+ START_TLS=true),
#         VERIFICATION_BASE_URL=<public origin>, and CAPTCHA_PROVIDER=turnstile (+ real keys).
#   To revert local to the in-memory mock emitter (no deliverable link): ONBOARDING_EMAIL_PROVIDER=mock.
# ---------------------------------------------------------------------------------------------------------------------
ONBOARDING_EMAIL_PROVIDER=smtp
ONBOARDING_SMTP_HOST=mailpit
ONBOARDING_SMTP_PORT=1025
ONBOARDING_SMTP_USERNAME=
ONBOARDING_SMTP_PASSWORD=
ONBOARDING_SMTP_START_TLS=false
ONBOARDING_SMTP_FROM=no-reply@cypherx.local
ONBOARDING_VERIFICATION_BASE_URL=http://localhost:8000
ONBOARDING_CAPTCHA_PROVIDER=mock

# ---------------------------------------------------------------------------------------------------------------------
# 5. SERVICE-TO-SERVICE BOOTSTRAP SECRETS — must MATCH on both sides (Auth's cypherx.service-auth.bootstrap-secrets
#    map AND each calling service's SERVICE_BOOTSTRAP_SECRET). Values mirror application-local.yaml. LOCAL-ONLY.
# ---------------------------------------------------------------------------------------------------------------------
SERVICE_BOOTSTRAP_SECRET_XAGENT=local-dev-xagent-secret
SERVICE_BOOTSTRAP_SECRET_LLMS=local-dev-llms-secret
SERVICE_BOOTSTRAP_SECRET_GUARDRAILS=local-dev-guardrails-secret
# rag mints outbound service tokens (rag -> llms) with this secret. If Auth ever enforces a rag bootstrap secret,
# add a matching entry to Auth's cypherx.service-auth.bootstrap-secrets map. LOCAL-ONLY value.
SERVICE_BOOTSTRAP_SECRET_RAG=local-dev-rag-secret
XAGENT_SERVICE_PRINCIPAL_NAME=xagent
# tool-flow-bridge mints outbound service tokens (bridge -> tool-registry) with this secret; it is also injected
# into Auth's cypherx.service-auth.bootstrap-secrets map (see the auth-service block). LOCAL-ONLY value.
SERVICE_BOOTSTRAP_SECRET_FLOWBRIDGE=local-dev-flowbridge-secret
# Tool Builder shared Node-RED secrets — the SAME values must reach BOTH the `nodered` container and the
# `tool-flow-bridge` STATIC_NODERED_* env (docker-compose wires both from these). LOCAL-ONLY values.
NODERED_ADMIN_TOKEN=local-dev-nodered-admin-token
NODERED_INVOKE_SECRET=local-dev-nodered-invoke-secret
NODERED_CREDENTIAL_SECRET=local-dev-nodered-credential-secret

# ---------------------------------------------------------------------------------------------------------------------
# 6. GUARDRAILS — redaction HMAC key. MUST be a real 32+ char secret (used to HMAC redacted PII). Change for non-local.
# ---------------------------------------------------------------------------------------------------------------------
REDACTION_HMAC_KEY_PLATFORM=local-dev-redaction-hmac-key-change-me-32chars

# ---------------------------------------------------------------------------------------------------------------------
# 7. LLM PROVIDERS + EMBEDDINGS + SEARCH — keep the mock toggles ON to run fully keyless (no outbound network).
#    To use real providers: flip the relevant toggle off and fill the API key(s).
# ---------------------------------------------------------------------------------------------------------------------
MOCK_PROVIDERS=true
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# rag/memory embeddings: use the deterministic in-process embedder (no llms-gateway service token needed).
MOCK_EMBEDDINGS=true
EMBEDDINGS_FALLBACK_TO_MOCK=true
# tool-web-search provider: 'mock' = deterministic, no network. Set 'serpapi'|'brave' + the key to go live.
SEARCH_PROVIDER=mock
SERPAPI_API_KEY=
BRAVE_API_KEY=

# ---------------------------------------------------------------------------------------------------------------------
# 8. GUARDRAILS CLASSIFIER — keep 'stub' (the 'ml' extra / detoxify is NOT installed in the image).
# ---------------------------------------------------------------------------------------------------------------------
CLASSIFIER_MODE=stub

# ---------------------------------------------------------------------------------------------------------------------
# 9. MISC / IDENTITY — safe defaults; leave as-is for local.
# ---------------------------------------------------------------------------------------------------------------------
ENVIRONMENT=local
DEPLOYMENT_ID=cypherx-local
LOG_LEVEL=INFO
JAVA_OPTS=-XX:MaxRAMPercentage=75.0
DB_POOL_MAX=10
LLMS_SERVICE_VERSION=0.1.0

# Demo BFF behaviour (only relevant under --profile demo).
DEMO_RESET_BOOTSTRAP=1
DEMO_SYSTEM_PROMPT=You are a helpful assistant. Answer concisely.
DEMO_MODEL=smart

# ---------------------------------------------------------------------------------------------------------------------
# 10. WP13 FRONTEND — BFF (security boundary) + SPA. The BFF holds the session KEK + the httpOnly session cookie.
# ---------------------------------------------------------------------------------------------------------------------
# 32-byte AES-256-GCM Key-Encryption-Key for the server-side session store, base64-encoded (decodes to EXACTLY 32
# bytes -> 44 base64 chars). REQUIRED — the BFF refuses to boot without it. Generate a fresh one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# The value below is a LOCAL-ONLY dev key (32 zero bytes) — DO NOT use it anywhere real.
SESSION_KEK_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# Cookie name the edge proxy checks for the edge-401 gate (Contract-15 case 5). Must match the BFF's cookie name.
SESSION_COOKIE_NAME=cypherx_sid
# BFF: allowed SPA origins (CORS/CSRF). For local split-origin via the edge, the SPA is reached at http://localhost:8000.
BFF_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Local http dev: cookies are NOT Secure (edge terminates plain http). Set true behind HTTPS.
BFF_COOKIE_SECURE=false
BFF_COOKIE_SAMESITE=lax
BFF_NODE_ENV=production
# SPA build-time BFF origin (inlined into the browser bundle; NO secret).
# DEFAULT (empty) = same-origin behind the edge: the SPA is served at :8000 (Caddy) and calls /bff/* on the
# SAME origin, which Caddy reverse-proxies to the BFF. Keeping it empty avoids a cross-origin (CORS) hard-block
# in the browser — the BFF registers no CORS plugin, so a direct cross-origin call to the BFF host port fails.
# Only set a full origin (e.g. http://localhost:8092) for split-origin dev where the BFF itself serves CORS;
# that is NOT the default compose topology. Rebuild frontend-app after changing (the value is baked at build).
NEXT_PUBLIC_BFF_URL=
NEXT_PUBLIC_BFF_PREFIX=/bff

# ---------------------------------------------------------------------------------------------------------------------
# 11. KAFKA TOPICS — topics-init one-shot tunables (applied to every created topic). Leave as-is for local.
# ---------------------------------------------------------------------------------------------------------------------
KAFKA_TOPIC_PARTITIONS=1
KAFKA_TOPIC_RETENTION_MS=604800000

# ---------------------------------------------------------------------------------------------------------------------
# 12. OBSERVABILITY (--profile observability) — OTLP export + Grafana login. Span export is OPT-IN: with
#     OTEL_EXPORTER_OTLP_ENDPOINT EMPTY the services do NOT export (complete no-op). To export, point it at the
#     collector and bring the profile up. Prometheus scrapes /metrics regardless (no endpoint needed there).
# ---------------------------------------------------------------------------------------------------------------------
# Set to http://otel-collector:4317 to turn ON span export (requires --profile observability up).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
XAGENT_OTEL_SERVICE_NAME=agent-runtime
# Grafana admin login (anonymous Viewer is also enabled). Change for anything non-local.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------------------------------------------------
# 13. RAG object storage (MinIO). The first-cycle ObjectStore uses fixed in-code creds; these only set bucket/endpoint.
# ---------------------------------------------------------------------------------------------------------------------
RAG_S3_BUCKET=cypherx-rag-documents-dev
RAG_S3_ENDPOINT=http://minio:9000
RAG_S3_SSE_MODE=none
