# =====================================================================================================================
# dev/local/seed/doppler.env.example — LOCAL development environment template (Phase 1, Component 17c / 20).
#
# PLACEHOLDERS ONLY. There are NO real keys in this file and there NEVER must be. In cloud envs these values come
# from Doppler (project: cypherx-platform, config: dev/staging/prod) and are synced into pods by the Doppler operator.
# Locally, copy this file and fill in the throwaway / your-own values:
#
#     cp dev/local/seed/doppler.env.example dev/local/.env
#     # edit dev/local/.env, then `tilt up` (or `docker compose --env-file dev/local/.env up`)
#
# dev/local/.env is gitignored. Do NOT commit a filled-in copy. Do NOT paste production secrets here.
#
# The connection strings below point at the docker-compose services using their COMPOSE/IN-CLUSTER DNS names
# (postgres, valkey, redpanda, minio). From a service running under Tilt/kind on the same docker network these names
# resolve directly. From your host shell, swap the hostnames for localhost.
# =====================================================================================================================

# ---------------------------------------------------------------------------------------------------------------------
# PostgreSQL (RDS substitute). Per-service DSNs use that service's runtime user (Component 14 naming).
# Cloud path: db/<svc>/runtime_password in Doppler. Local: the throwaway CYPHERX_LOCAL_DB_PASSWORD (default "localdev").
# ---------------------------------------------------------------------------------------------------------------------
CYPHERX_LOCAL_DB_PASSWORD=localdev

# Generic DSN (admin) — handy for psql / one-off tooling. sslmode=disable because local Postgres has no TLS.
POSTGRES_DSN=postgresql://cypherx_admin:localdev@postgres:5432/cypherx_platform?sslmode=disable

# Per-service runtime DSNs (each scoped to its schema via search_path). Mirrors the cloud PgBouncer database entries.
AUTH_POSTGRES_DSN=postgresql://auth_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=auth
LLMS_POSTGRES_DSN=postgresql://llms_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=llms
GUARDRAILS_POSTGRES_DSN=postgresql://grd_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=guardrails
MEMORY_POSTGRES_DSN=postgresql://mem_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=memory
RAG_POSTGRES_DSN=postgresql://rag_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=rag
XAGENT_POSTGRES_DSN=postgresql://xagent_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=xagent
PLATFORM_POSTGRES_DSN=postgresql://plat_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=platform

# DDL DSN example (Atlas migration jobs use the *_ddl user). One per service in cloud; shown for auth here.
AUTH_DDL_POSTGRES_DSN=postgresql://auth_ddl:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=auth

# ---------------------------------------------------------------------------------------------------------------------
# Valkey (ElastiCache substitute). No AUTH token / TLS locally. Cloud: VALKEY_URL with rediss:// + AUTH from Doppler.
# Used for idempotency keys (Contract 9), JWKS cache, rate limiting.
# ---------------------------------------------------------------------------------------------------------------------
VALKEY_URL=redis://valkey:6379/0
VECTOR_STORE_URL=postgresql://mem_user:localdev@postgres:5432/cypherx_platform?sslmode=disable&search_path=memory

# ---------------------------------------------------------------------------------------------------------------------
# Kafka (MSK substitute = Redpanda). PLAINTEXT locally (no SASL/TLS). Cloud: SASL_SSL SCRAM-SHA-512 on :9096.
# Use the INTERNAL listener name redpanda:29092 from inside the compose/kind network.
# ---------------------------------------------------------------------------------------------------------------------
KAFKA_BROKERS=redpanda:29092
KAFKA_SCHEMA_REGISTRY_URL=http://redpanda:8081
# Present so config shape matches cloud; blank locally because there is no SASL.
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ---------------------------------------------------------------------------------------------------------------------
# S3 (MinIO substitute). S3-compatible endpoint + path-style addressing (MinIO requires path-style).
# Cloud: IRSA-assumed role, no static keys. Local: throwaway root creds from docker-compose.
# ---------------------------------------------------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=cypherxlocal
S3_SECRET_KEY=cypherxlocal
S3_FORCE_PATH_STYLE=true
S3_BUCKET=cypherx-rag-documents-dev

# ---------------------------------------------------------------------------------------------------------------------
# Service-to-service auth bootstrap (Contract 12). Cloud: service-auth/<svc>/bootstrap_secret in Doppler.
# Locally these are placeholders so services can boot their token-mint loop against a local Auth.
# ---------------------------------------------------------------------------------------------------------------------
AUTH_ISSUER_URL=http://auth-service:8080
AUTH_PLATFORM_AUDIENCE=cypherx-platform
AUTH_SERVICE_URL=http://auth-service:8080
# xAgent downstream services (in-network DNS, container port 8080). The host-shell local
# recipe overrides these to http://localhost:8085 / :8086 (see xAgent core/config.py defaults).
LLMS_GATEWAY_URL=http://llms-gateway:8080
GUARDRAILS_SERVICE_URL=http://guardrails-service:8080
# MUST equal the secret Auth compares against (service-auth.bootstrap-secrets.xagent).
# Local Auth (application-local.yaml) uses 'local-dev-xagent-secret' — keep these in sync or
# xAgent's POST /v1/service-tokens 401s and every guardrails/LLM call fails SERVICE_UNAVAILABLE.
SERVICE_BOOTSTRAP_SECRET=local-dev-xagent-secret

# JWT signing material (Contract 1). Cloud: shared-core.auth config in Doppler (JWT_PRIVATE_KEY/PUBLIC_KEY/SIGNING_KID).
# Locally, generate a throwaway RS256 keypair and paste here, or let Auth generate one on first boot.
JWT_PRIVATE_KEY=changeme-generate-an-rs256-private-key
JWT_PUBLIC_KEY=changeme-generate-the-matching-public-key
JWT_SIGNING_KID=local-dev-kid-1

# ---------------------------------------------------------------------------------------------------------------------
# LLM provider keys — REQUIRED for real model calls; otherwise services run in mock/echo mode.
# NEVER commit a real key. Leave as "changeme" to disable live LLM calls locally.
# ---------------------------------------------------------------------------------------------------------------------
ANTHROPIC_API_KEY=changeme
OPENAI_API_KEY=changeme

# ---------------------------------------------------------------------------------------------------------------------
# Runtime context (mirrors Contract 6 log fields + standard service env).
# ---------------------------------------------------------------------------------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=DEBUG
